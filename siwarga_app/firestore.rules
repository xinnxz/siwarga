rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // MVP RT internal — pengguna harus login.
    // TODO: perketat per koleksi & rt_id sesuai docs/architecture/03-security-architecture.md
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
